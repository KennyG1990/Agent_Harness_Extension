    "configuration": {
      "title": "Forge Agent Settings",
      "properties": {
        "forge.providerDefault": {
          "type": "string",
          "default": "openrouter",
          "enum": [
            "openrouter",
            "openai-compatible"
          ],
          "description": "Default model provider."
        },
        "forge.maxCostUsd": {
          "type": "number",
          "default": 1,
          "description": "Budget cap: halt the run (as gave_up) once provider spend reaches this many USD."
        },
        "forge.maxWallClockMinutes": {
          "type": "number",
          "default": 30,
          "description": "Budget cap: halt the run once wall-clock exceeds this many minutes."
        },
        "forge.maxSteps": {
          "type": "number",
          "default": 30,
          "description": "Maximum harness steps per run."
        },
        "forge.reflectionEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Bounded reflection: on failures, feed the reason back and retry (proven +100pt solve-rate delta). Disable only for A/B experiments."
        },
        "forge.architectModel": {
          "type": "string",
          "default": "",
          "description": "Optional stronger planning model for product and eval architect lanes (plan big, execute small)."
        },
        "forge.openAiCompatibleBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "OpenAI-compatible fallback endpoint."
        },
        "forge.defaultCodingModel": {
          "type": "string",
          "default": "openrouter/pareto-code",
          "description": "Default coding model route."
        },
        "forge.defaultMixedModel": {
          "type": "string",
          "default": "openrouter/auto",
          "description": "Default mixed/non-coding model route."
        },
        "forge.promptEnhancementModel": {
          "type": "string",
          "default": "google/gemini-2.5-flash-lite",
          "description": "Exact inexpensive model slug used only when the user explicitly clicks Enhance Prompt. Enhancement never auto-submits or mutates the workspace."
        },
        "forge.semanticRetrievalEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Opt in to sending bounded repository text to the configured embedding provider for hybrid semantic retrieval. Disabled by default for source privacy."
        },
        "forge.costAwareRoutingEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Opt in to host-owned least-expensive-capable routing for Explorer and Editor workers within the explicit worker model pool. Architect, Reviewer, and Escalation bindings remain authoritative."
        },
        "forge.workerModelPool": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Ordered exact model slugs eligible for cost-aware Explorer/Editor routing. Unknown-price models rank after known-price capable models."
        },
        "forge.humanApprovalPolicy": {
          "type": "string",
          "default": "ask",
          "enum": [
            "ask",
            "auto"
          ],
          "enumDescriptions": [
            "Pause before validated file changes and commands so the user can approve or reject them.",
            "Commit validated actions automatically; deterministic firewall, review, checkpoint, and oracle gates remain enforced."
          ],
          "description": "Human approval policy for consequential workspace actions."
        },
        "forge.assuranceLevel": {
          "type": "string",
          "default": "standard",
          "enum": ["standard", "verified", "audited"],
          "enumDescriptions": [
            "Current full harness compatibility with explicit execution-contract confirmation.",
            "Require model-driven execution, zero fallback actions, green oracles, and independent diff review.",
            "Verified requirements plus proven isolation, calibrated oracles, and signed attestations. Unavailable until those capabilities are proven."
          ],
          "description": "Assurance policy compiled into and confirmed with each execution contract."
        },
        "forge.computerUseEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable governed Windows UI Automation inspection. Computer actions still always require explicit approval."
        },
        "forge.computerUseAllowedWindows": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Exact top-level window titles Forge may inspect and interact with."
        },
        "forge.embeddingModel": {
          "type": "string",
          "default": "openai/text-embedding-3-small",
          "description": "OpenRouter embedding model used when semantic retrieval is explicitly enabled."
        },
        "forge.mcpServers": {
          "type": "array",
          "default": [],
          "description": "Governed local MCP servers. Each exposed tool requires an exact policy. Store credentials with Forge Agent: Set MCP Credential, never in this setting.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "enabled",
              "transport",
              "tools"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "enabled": {
                "type": "boolean"
              },
              "transport": {
                "type": "string",
                "enum": [
                  "stdio",
                  "streamable-http"
                ]
              },
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "cwd": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "credentialBindings": {
                "type": "object"
              },
              "tools": {
                "type": "object"
              }
            }
          }
        },
        "forge.mcpTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 120000,
          "description": "Bounded timeout for MCP discovery and calls. Timeout does not weaken tool policy, approval, or evidence requirements."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./tsconfig.json && npm run bundle:extension && vite build",
    "watch": "tsc -watch -p ./tsconfig.json",
    "compile": "tsc -p ./tsconfig.json && npm run bundle:extension && vite build",
    "bundle:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --external:chromium-bidi/* --outfile=out/extension.js && esbuild src/harness/workerHost.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --external:chromium-bidi/* --outfile=out/workerHost.js && npm run copy:runtime-assets",
    "copy:runtime-assets": "node scripts/copy-runtime-assets.mjs",
    "test": "node scripts/smoke-tests.mjs",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "test:visual": "node scripts/visual-smoke.mjs",
    "test:browser": "npm run compile && node scripts/browser-validation-smoke.mjs",
    "test:browser-use": "npm run compile && node scripts/browser-use-smoke.mjs",
    "test:computer-use": "npm run compile && node scripts/computer-use-smoke.mjs",
    "test:progress": "npm run compile && node scripts/progress-stream-smoke.mjs",
    "test:readiness": "npm run compile && node scripts/provider-readiness-smoke.mjs",
    "test:modes": "npm run compile && node scripts/mode-registry-smoke.mjs",
    "test:support": "npm run compile && node scripts/support-report-smoke.mjs",
    "test:sessions": "npm run compile && node scripts/session-store-smoke.mjs",
    "test:difficult-proof": "npm run compile && node scripts/difficult-live-proof-smoke.mjs",
    "test:approvals": "npm run compile && node scripts/human-approval-smoke.mjs",
    "test:index": "npm run compile && node scripts/workspace-index-smoke.mjs",
    "test:context": "npm run compile && node scripts/composer-context-smoke.mjs",
    "test:conversation": "npm run compile && node scripts/conversation-controller-smoke.mjs",
    "test:mcp": "npm run compile && node scripts/mcp-gateway-smoke.mjs",
    "test:subagents": "npm run compile && node scripts/persistent-subagent-smoke.mjs",
    "test:isolation": "npm run compile && node scripts/runtime-isolation-smoke.mjs",
    "test:optimization": "npm run compile && node scripts/context-model-optimization-smoke.mjs",
    "test:topology": "npm run compile && node scripts/plan-big-execute-small-smoke.mjs",
    "test:production-benchmark": "npm run compile && node scripts/production-benchmark-smoke.mjs",
    "test:model-prompts": "npm run compile && node scripts/model-prompt-profile-smoke.mjs",
    "test:prompt-enhancement": "npm run compile && node scripts/prompt-enhancement-mcp-onboarding-smoke.mjs",
    "test:execution-contract": "npm run compile && node scripts/execution-contract-assurance-smoke.mjs",
    "test:workers": "npm run compile && node scripts/worker-process-stress.mjs 100",
    "eval": "npm run compile && node scripts/weak-model-eval.mjs",
    "eval:reflection": "npm run compile && node scripts/reflection-ab-eval.mjs",
    "eval:tier2": "npm run compile && node scripts/weak-model-eval-tier2.mjs",
    "eval:tier3": "npm run compile && node scripts/weak-model-eval-tier3.mjs",
    "eval:tier4": "npm run compile && node scripts/weak-model-eval-tier4.mjs",
    "eval:production": "npm run compile && node scripts/production-benchmark.mjs",
    "package": "vsce package --allow-missing-repository --no-dependencies"
  },
